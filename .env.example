# LLM
OPENAI_API_KEY=sk-...
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_GRADER_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Observability
LANGSMITH_API_KEY=lsv2_...
