# Provider selection
LLM_PROVIDER=openai          # openai | anthropic | gemini
EMBEDDING_PROVIDER=openai    # openai | gemini  (Anthropic has no embedding model)

# OpenAI (used when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_GRADER_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_GENERATION_MODEL=claude-sonnet-4-6
ANTHROPIC_GRADER_MODEL=claude-haiku-4-5-20251001

# Google Gemini (used when LLM_PROVIDER=gemini or EMBEDDING_PROVIDER=gemini)
GOOGLE_API_KEY=AIza...
GOOGLE_GENERATION_MODEL=gemini-2.0-flash
GOOGLE_GRADER_MODEL=gemini-2.0-flash-lite
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# Observability
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=dell-rag-platform

# Storage
STORAGE_BASE_PATH=./storage
MASTER_DB_PATH=./storage/tenants.db

# Redis (cache, rate-limits, arq queue, FAISS write locks)
REDIS_URL=redis://localhost:6379/0

# Platform
PLATFORM_ADMIN_KEY=change-me-before-deploying
ENVIRONMENT=development
